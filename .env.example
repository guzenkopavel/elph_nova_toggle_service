# Environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=false

# Database (required in staging/production; defaults to SQLite for local dev)
# DATABASE_URL=sqlite:./data/feature-config.db

# Manifest (required; defaults to local dev path)
# MANIFEST_PATH=./manifest/elph-nova-feature-manifest.json
# DEFAULT_PRODUCT_ID=elph_nova

# Public and admin base URLs (optional; used for self-referential link generation)
# FEATURE_CONFIG_PUBLIC_BASE_URL=http://127.0.0.1:3000
# FEATURE_CONFIG_ADMIN_BASE_URL=http://127.0.0.1:3000

# SSO / JWKS (optional for local dev; required when bearer token verification is active)
# SSO_JWKS_URI=https://sso.example.com/.well-known/jwks.json
# SSO_ISSUER=https://sso.example.com
# SSO_AUDIENCE=feature-config-service

# Admin session (optional for local dev; required in staging/production)
# ADMIN_SESSION_SECRET=replace-with-long-random-secret-minimum-32-chars
# ADMIN_ALLOWED_IPS=127.0.0.1

# Dev only — forbidden on production
# DEV_ADMIN_PASSWORD=replace-for-local-dev-only

# CORS (optional; comma-separated list of allowed origins)
# CORS_ALLOWED_ORIGINS=http://localhost:3000
