# ──────────────────────────────────────────────────────────────────
# Elph Nova Feature Config Service — environment variables
#
# Copy this file to .env and fill in the values before running
# docker compose up -d
# ──────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Set to true only when running behind a trusted reverse proxy (nginx, Caddy, etc.)
# Also set TRUSTED_PROXY_IPS when enabling this in production.
TRUST_PROXY=false
# TRUSTED_PROXY_IPS=127.0.0.1,10.0.0.0/8

# ── Docker Compose ────────────────────────────────────────────────
# Host port to expose (the container always listens on 3000)
HOST_PORT=3000

# ── Database ─────────────────────────────────────────────────────
# PostgreSQL password — used by both the db service and DATABASE_URL
POSTGRES_PASSWORD=changeme

# DATABASE_URL is set automatically in docker-compose.yml.
# Override only if you're connecting to an external database:
# DATABASE_URL=postgres://feature_config:changeme@your-db-host:5432/feature_config

# ── Manifest ─────────────────────────────────────────────────────
DEFAULT_PRODUCT_ID=elph_nova
# MANIFEST_PATH is set in docker-compose.yml to /app/manifest/...

# ── Admin auth (required in production) ──────────────────────────
# Generate with: openssl rand -hex 32
ADMIN_COOKIE_SECRET=replace-with-32-plus-char-random-secret-here
# ADMIN_SESSION_SECRET=replace-with-another-32-plus-char-secret

# Restrict admin UI access to specific IPs (comma-separated). Leave empty to allow all.
# ADMIN_ALLOWED_IPS=127.0.0.1,10.0.0.1

# ── SSO / JWKS ───────────────────────────────────────────────────
# Leave empty to allow anonymous and authenticated configs without JWT verification.
# When set in non-dev, SSO_ISSUER and SSO_AUDIENCE are also required.
# SSO_JWKS_URI=https://sso.example.com/.well-known/jwks.json
# SSO_ISSUER=https://sso.example.com
# SSO_AUDIENCE=feature-config-service
# SSO_JWKS_TIMEOUT_MS=3000

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated allowed origins for the public API.
# Use "none" to deny all cross-origin requests (safe default for internal APIs).
CORS_ALLOWED_ORIGINS=none
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://app2.example.com

# ── Base URLs (optional) ──────────────────────────────────────────
# Used for self-referential links in responses.
# FEATURE_CONFIG_PUBLIC_BASE_URL=https://feature-config.example.com
# FEATURE_CONFIG_ADMIN_BASE_URL=https://feature-config.example.com

# ── Rate limits ──────────────────────────────────────────────────
# RATE_LIMIT_PUBLIC_MAX=300
# RATE_LIMIT_ADMIN_MAX=100

# ── Dev only (forbidden in production) ────────────────────────────
# DEV_ADMIN_PASSWORD=local-dev-only
