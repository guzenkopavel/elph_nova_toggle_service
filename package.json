{
  "name": "elph-nova-feature-config-service",
  "version": "0.1.0",
  "private": true,
  "description": "Feature Config Service for Elph Nova — stage-1",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "postbuild": "cp -r src/views dist/src/",
    "start": "node dist/src/server.js",
    "start:dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "knex migrate:latest --knexfile knexfile.ts",
    "sync-manifest": "tsx scripts/sync-manifest.ts",
    "smoke:rollout": "bash scripts/smoke-rollout.sh"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/csrf-protection": "^6.4.1",
    "@fastify/formbody": "^7.0.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/view": "^9.1.0",
    "fastify": "^4.28.0",
    "jose": "^5.9.0",
    "knex": "^3.1.0",
    "nunjucks": "^3.2.4",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "semver": "^7.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/nunjucks": "^3.2.6",
    "@types/pg": "^8.11.0",
    "@types/semver": "^7.5.0",
    "better-sqlite3": "^11.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
