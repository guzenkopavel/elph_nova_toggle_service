{% extends "layout.njk" %}

{% block title %}{{ featureKey }}{% endblock %}

{% block content %}
<h1>{{ featureKey }}</h1>
{% if definition %}
<p><strong>Название:</strong> {{ definition.name }}</p>
{% if definition.description %}<p><strong>Описание:</strong> {{ definition.description }}</p>{% endif %}
<p><strong>По умолчанию:</strong> <code>{{ definition.default_entry_json }}</code></p>
{% endif %}

<h2>Активные правила</h2>
{% if rules.length %}
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Аудитория</th>
      <th>Платформа</th>
      <th>Мин. версия</th>
      <th>Макс. версия</th>
      <th>Включён</th>
      <th>Payload</th>
      <th>Действия</th>
    </tr>
  </thead>
  <tbody>
    {% for rule in rules %}
    <tr>
      <td>{{ rule.id }}</td>
      <td>{{ rule.audience }}</td>
      <td>{{ rule.platform }}</td>
      <td>{{ rule.min_app_version or "-" }}</td>
      <td>{{ rule.max_app_version or "-" }}</td>
      <td>{{ "✓ Да" if rule.is_enabled else "✗ Нет" }}</td>
      <td><code>{{ rule.payload_json if rule.payload_json else "—" }}</code></td>
      <td>
        <a href="/admin/features/{{ featureKey }}/rules/{{ rule.id }}/edit">Изменить</a>
        &nbsp;
        <form method="POST" action="/admin/features/{{ featureKey }}/rules/{{ rule.id }}/disable" style="display:inline">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="reason" value="отключено через UI">
          <input type="hidden" name="expected_revision" value="{{ currentRevision }}">
          <button type="submit" onclick="return confirm('Отключить правило {{ rule.id }}?')">Отключить</button>
        </form>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p>Нет активных правил для этой фичи.</p>
{% endif %}

<p><a href="/admin/features/{{ featureKey }}/rules/new">+ Добавить правило</a></p>

<h2>Быстрый тогл</h2>
<form method="POST" action="/admin/features/{{ featureKey }}/quick-toggle"
      hx-post="/admin/features/{{ featureKey }}/quick-toggle"
      hx-target="body"
      hx-push-url="true">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
  <input type="hidden" name="expected_revision" value="{{ currentRevision }}">
  <button type="submit" name="enabled" value="true">Включить всё</button>
  <button type="submit" name="enabled" value="false">Отключить всё</button>
</form>

{% if errorMessage %}
<p class="error">{{ errorMessage }}</p>
{% endif %}

<h2>Зависимости</h2>
<p>Зависимости гарантируют, что дочерняя фича автоматически отключается, если родительская отключена (логика И).</p>

{% if parentEdges.length %}
<h3>Эта фича зависит от (родители):</h3>
<table>
  <thead>
    <tr><th>Ключ родителя</th><th>Причина</th><th>Действия</th></tr>
  </thead>
  <tbody>
    {% for edge in parentEdges %}
    <tr>
      <td><a href="/admin/features/{{ edge.parent_feature_key }}">{{ edge.parent_feature_key }}</a></td>
      <td>{{ edge.reason or "-" }}</td>
      <td>
        <form method="POST" action="/admin/features/{{ featureKey }}/dependencies/{{ edge.id }}/remove" style="display:inline">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="expected_revision" value="{{ currentRevision }}">
          <input type="text" name="reason" placeholder="причина (необязательно)" style="width:150px">
          <button type="submit" onclick="return confirm('Удалить зависимость?')">Удалить</button>
        </form>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p>Нет родительских зависимостей.</p>
{% endif %}

{% if childEdges.length %}
<h3>Фичи, зависящие от этой (дочерние):</h3>
<table>
  <thead>
    <tr><th>Ключ дочернего</th><th>Причина</th><th>Действия</th></tr>
  </thead>
  <tbody>
    {% for edge in childEdges %}
    <tr>
      <td><a href="/admin/features/{{ edge.child_feature_key }}">{{ edge.child_feature_key }}</a></td>
      <td>{{ edge.reason or "-" }}</td>
      <td>
        <form method="POST" action="/admin/features/{{ edge.child_feature_key }}/dependencies/{{ edge.id }}/remove" style="display:inline">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="expected_revision" value="{{ currentRevision }}">
          <input type="text" name="reason" placeholder="причина (необязательно)" style="width:150px">
          <button type="submit" onclick="return confirm('Удалить зависимость?')">Удалить</button>
        </form>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p>Нет дочерних зависимостей.</p>
{% endif %}

<h3>Добавить зависимость</h3>
<form method="POST" action="/admin/features/{{ featureKey }}/dependencies/add">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
  <input type="hidden" name="expected_revision" value="{{ currentRevision }}">
  <div>
    <label>Связь:</label>
    <select name="direction">
      <option value="child">{{ featureKey }} зависит от (родитель):</option>
      <option value="parent">Сделать {{ featureKey }} родителем (дочерний):</option>
    </select>
    <input type="text" name="other_key" placeholder="feature_key" required>
  </div>
  <div>
    <label>Причина (необязательно):</label>
    <input type="text" name="reason" placeholder="необязательная причина">
  </div>
  <button type="submit">Добавить зависимость</button>
</form>
{% if depErrorMessage %}
<p class="error">{{ depErrorMessage }}</p>
{% endif %}
{% endblock %}
