{% extends "layout.njk" %}

{% block title %}Фичи{% endblock %}

{% block content %}
<h1>Фича-тоглы</h1>
<table>
  <thead>
    <tr>
      <th>Ключ</th>
      <th>Название</th>
      <th>По умолчанию</th>
      <th>Активные правила</th>
      <th>Зависимости</th>
      <th>Действия</th>
    </tr>
  </thead>
  <tbody>
    {% for feature in features %}
    <tr>
      <td><a href="/admin/features/{{ feature.feature_key }}">{{ feature.feature_key }}</a></td>
      <td>{{ feature.name }}</td>
      <td>{{ "✓ Вкл" if feature.defaultIsEnabled else "✗ Выкл" }}</td>
      <td>{{ feature.activeRuleCount }}</td>
      <td>{{ feature.depCount }}</td>
      <td><a href="/admin/features/{{ feature.feature_key }}">Открыть</a></td>
    </tr>
    {% else %}
    <tr><td colspan="6">Фичи не найдены в манифесте.</td></tr>
    {% endfor %}
  </tbody>
</table>
{% endblock %}
