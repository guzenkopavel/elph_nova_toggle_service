<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Вход — Feature Toggles</title>
  <style>
    body { font-family: system-ui; max-width: 400px; margin: 6rem auto; padding: 0 1rem; }
    h1 { margin-bottom: 1.5rem; }
    label { display: block; margin-top: 0.75rem; font-weight: 500; }
    input[type=password] { width: 100%; padding: 0.4rem; box-sizing: border-box; margin-top: 0.25rem; }
    input[type=submit] { margin-top: 1rem; padding: 0.5rem 1.5rem; cursor: pointer; }
    .error { color: red; margin-top: 0.75rem; }
  </style>
</head>
<body>
  <h1>Вход в панель управления</h1>
  {% if error %}
    <p class="error">{{ error }}</p>
  {% endif %}
  <form method="POST" action="/admin/login">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <label for="password">Пароль</label>
    <input type="password" id="password" name="password" autofocus required>
    <input type="submit" value="Войти">
  </form>
</body>
</html>
