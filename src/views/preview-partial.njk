{% if error %}
<p class="error">{{ error }}</p>
{% elif features %}
<h2>Разрешённые фичи (ревизия {{ revision }})</h2>
<table>
  <thead>
    <tr>
      <th>Ключ фичи</th>
      <th>Включён</th>
      <th>Значение</th>
    </tr>
  </thead>
  <tbody>
    {% for key, value in features %}
    <tr>
      <td>{{ key }}</td>
      <td>{{ "✓ Да" if value.isEnabled else "✗ Нет" }}</td>
      <td><code>{{ value | dump }}</code></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p>Заполните параметры выше и нажмите «Просмотр».</p>
{% endif %}
