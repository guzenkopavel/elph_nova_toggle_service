{% extends "layout.njk" %}

{% block title %}Предпросмотр конфигурации{% endblock %}

{% block content %}
<h1>Предпросмотр конфигурации</h1>

<form id="preview-form"
      hx-get="/admin/preview/partial"
      hx-target="#preview-results"
      hx-push-url="false">
  <label for="platform">Платформа</label>
  <select id="platform" name="platform" required style="width:auto">
    <option value="" {{ "selected" if not platform }}>-- Выбрать --</option>
    <option value="ios" {{ "selected" if platform == "ios" }}>ios</option>
    <option value="android" {{ "selected" if platform == "android" }}>android</option>
    <option value="web" {{ "selected" if platform == "web" }}>web</option>
    <option value="desktop" {{ "selected" if platform == "desktop" }}>desktop</option>
  </select>

  <label for="appVersion">Версия приложения</label>
  <input type="text" id="appVersion" name="appVersion" value="{{ appVersion or "" }}" placeholder="напр. 1.0.0" style="width:auto">

  <label for="audience">Аудитория</label>
  <select id="audience" name="audience" style="width:auto">
    <option value="anonymous" {{ "selected" if audience == "anonymous" or not audience }}>анонимные</option>
    <option value="authenticated" {{ "selected" if audience == "authenticated" }}>авторизованные</option>
  </select>

  <br><br>
  <button type="submit">Просмотр</button>
</form>

<div id="preview-results">
  {% if features %}
  {% include "preview-partial.njk" %}
  {% endif %}
</div>
{% endblock %}
