{% extends "layout.njk" %}

{% block title %}{% if editMode %}Редактировать{% else %}Новое{% endif %} правило — {{ featureKey }}{% endblock %}

{% block content %}
<h1>{% if editMode %}Редактировать{% else %}Новое{% endif %} правило для {{ featureKey }}</h1>

{% if errorMessage %}
<p class="error">{{ errorMessage }}</p>
{% endif %}

<form method="POST" action="{{ formAction }}">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
  <input type="hidden" name="expected_revision" value="{{ currentRevision }}">

  <label for="audience">Аудитория</label>
  <select id="audience" name="audience" required>
    <option value="all" {% if (rule and rule.audience == "all") or (not rule) %}selected{% endif %}>все</option>
    <option value="anonymous" {% if rule and rule.audience == "anonymous" %}selected{% endif %}>анонимные</option>
    <option value="authenticated" {% if rule and rule.audience == "authenticated" %}selected{% endif %}>авторизованные</option>
  </select>

  <label for="platform">Платформа</label>
  <select id="platform" name="platform" required>
    <option value="all" {% if (rule and rule.platform == "all") or (not rule) %}selected{% endif %}>все</option>
    <option value="ios" {% if rule and rule.platform == "ios" %}selected{% endif %}>ios</option>
    <option value="android" {% if rule and rule.platform == "android" %}selected{% endif %}>android</option>
    <option value="web" {% if rule and rule.platform == "web" %}selected{% endif %}>web</option>
    <option value="desktop" {% if rule and rule.platform == "desktop" %}selected{% endif %}>desktop</option>
  </select>

  <label for="min_app_version">Мин. версия приложения (необязательно)</label>
  <input type="text" id="min_app_version" name="min_app_version" value="{{ rule.min_app_version if rule else '' }}" placeholder="напр. 1.0.0">

  <label for="max_app_version">Макс. версия приложения (необязательно)</label>
  <input type="text" id="max_app_version" name="max_app_version" value="{{ rule.max_app_version if rule else '' }}" placeholder="напр. 2.0.0">

  <label style="display:flex;align-items:center;gap:0.5rem;margin-top:0.75rem">
    <input type="checkbox" id="is_enabled" name="is_enabled" value="true" style="width:auto"
      {% if rule %}{% if rule.is_enabled %}checked{% endif %}{% else %}checked{% endif %}>
    Включить фичу (isEnabled)
  </label>

  <label for="payload_json">Payload (JSON, необязательно)</label>
  <textarea id="payload_json" name="payload_json" rows="4" placeholder='{"key":"value"}'>{{ rule.payload_json if rule else '' }}</textarea>

  <label for="reason">Причина <span style="color:red">*</span></label>
  <input type="text" id="reason" name="reason" value="{{ rule.reason if rule else '' }}" required placeholder="Опишите причину изменения">

  <br><br>
  <input type="submit" value="{% if editMode %}Сохранить{% else %}Создать{% endif %}">
  &nbsp;
  <a href="/admin/features/{{ featureKey }}">Отмена</a>
</form>
{% endblock %}
